{
  "annotations": { "list": [] },
  "editable": true,
  "fgraphTooltip": 1,
  "id": null,
  "panels": [
    {
      "type": "stat",
      "title": "Pedidos creados (total)",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(brewrelay_orders_total)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue" }] }
        }
      },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat",
      "title": "Notificaciones barista (total)",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum(brewrelay_notifications_total)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }] }
        }
      },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat",
      "title": "Pedidos CREATED",
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "brewrelay_orders_by_status{status=\"CREATED\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "yellow" }] }
        }
      },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat",
      "title": "Pedidos PREPARING",
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "brewrelay_orders_by_status{status=\"PREPARING\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "orange" }] }
        }
      },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat",
      "title": "Pedidos READY",
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 0 },
      "targets": [
        {
          "expr": "brewrelay_orders_by_status{status=\"READY\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }] }
        }
      },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "timeseries",
      "title": "Pedidos vs Notificaciones (rate por minuto)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 5 },
      "targets": [
        {
          "expr": "rate(brewrelay_orders_total[1m]) * 60",
          "legendFormat": "pedidos/min",
          "refId": "A"
        },
        {
          "expr": "rate(brewrelay_notifications_total[1m]) * 60",
          "legendFormat": "notificaciones/min",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "type": "timeseries",
      "title": "Pedidos por estado (gauge)",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 5 },
      "targets": [
        {
          "expr": "brewrelay_orders_by_status",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "type": "timeseries",
      "title": "PostgreSQL — transacciones commit/s",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{datname=\"brewrelay\"}[1m])",
          "legendFormat": "commits/s",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback{datname=\"brewrelay\"}[1m])",
          "legendFormat": "rollbacks/s",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "type": "timeseries",
      "title": "PostgreSQL — conexiones activas",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "expr": "pg_stat_database_numbackends{datname=\"brewrelay\"}",
          "legendFormat": "backends",
          "refId": "A"
        },
        {
          "expr": "pg_stat_activity_count{datname=\"brewrelay\",state=\"active\"}",
          "legendFormat": "active",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "type": "stat",
      "title": "Replication slot lag (bytes)",
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 22 },
      "targets": [
        {
          "expr": "pg_replication_slot_pg_wal_lsn_diff{slot_name=\"brewrelay_slot\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }, { "color": "yellow", "value": 1000000 }, { "color": "red", "value": 10000000 }] }
        }
      },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat",
      "title": "Tamaño de la DB",
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 22 },
      "targets": [
        {
          "expr": "pg_database_size_bytes{datname=\"brewrelay\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat",
      "title": "Tuplas insertadas (total)",
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 22 },
      "targets": [
        {
          "expr": "sum(pg_stat_database_tup_inserted{datname=\"brewrelay\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    }
  ],
  "schemaVersion": 39,
  "tags": ["brewrelay", "outbox", "postgres"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
